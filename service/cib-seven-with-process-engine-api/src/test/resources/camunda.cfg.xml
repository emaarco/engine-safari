<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans.xsd">

  <bean id="processEngineConfiguration"
        class="org.cibseven.bpm.engine.impl.cfg.StandaloneInMemProcessEngineConfiguration">
    <property name="processEngineName" value="jgiven-test" />
    <property name="jobExecutorActivate" value="false" />
    <property name="history" value="full" />
    <property name="jdbcUrl" value="jdbc:h2:mem:cib-seven-pea-jgiven;DB_CLOSE_DELAY=-1" />
  </bean>

</beans>
